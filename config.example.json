{
  "cli_path": "olares-cli",
  "install_timeout_minutes": 90,
  "uninstall_timeout_minutes": 30,
  "request_timeout_seconds": 1800,
  "pull_timeout_seconds": 3600,
  "api_ready_timeout_minutes": 60,
  "api_ready_probe_interval_seconds": 30,
  "warmup_retries": 10,
  "warmup_retry_sleep_seconds": 30,
  "pull_max_attempts": 5,
  "pull_retry_sleep_seconds": 30,
  "delete_data": true,
  "pull_model": false,
  "auto_open_internal_entrance": true,
  "skip_install_if_running": true,
  "preserve_if_existed": false,
  "uninstall_after_run": true,
  "cooldown_seconds": 30,
  "output_dir": "/home/olares/test",
  "save_pod_logs_on_failure": true,
  "pod_logs_dir": "/tmp",
  "sudo_password": "",

  "openai_defaults": {
    "api_key": "EMPTY",
    "endpoint": "chat",
    "max_tokens": 256,
    "temperature": 0.0,
    "top_p": null,
    "extra_headers": {},
    "extra_body": {},
    "measure_ttft_approx": true
  },

  "models": [
    {
      "app_name": "ollamadeepseekr114bv2",
      "model_name": "deepseek-r1:14b",
      "api_type": "ollama",
      "thinking": true
    },
    {
      "app_name": "ollamaqwen314bv2",
      "model_name": "qwen3:14b",
      "api_type": "ollama",
      "thinking": true
    },
    {
      "app_name": "vllmgemma312bitv2",
      "model_name": "google/gemma-3-12b-it",
      "api_type": "openai",
      "thinking": false,
      "install_timeout_minutes": 120,
      "openai": {
        "max_tokens": 512,
        "measure_ttft_approx": false
      }
    },
    {
      "app_name": "llamacppgptoss120bggufv2",
      "model_name": "gpt-oss-120b",
      "api_type": "openai",
      "thinking": false,
      "install_timeout_minutes": 240
    }
  ],

  "questions": [
    "请用一句话介绍人工智能。"
  ],

  "email": {
    "smtp_host": "smtp.gmail.com",
    "smtp_port": 465,
    "use_ssl": true,
    "smtp_timeout": 120,
    "smtp_retries": 3,
    "smtp_retry_backoff": 5,
    "username": "you@example.com",
    "password": "<gmail-app-password>",
    "from": "you@example.com",
    "to": "you@example.com",
    "subject": "Olares LLM benchmark"
  }
}
